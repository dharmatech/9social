#!/bin/rc
rfork en
repo=`{echo $0 | sed 's;/tests/perf/[^/]*$;;'}
repo=`{cd $repo && pwd}
addcount=3

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: tests/perf/index-update.rc <root> <user>' >[1=2]
	exit usage
}

fn checkroot {
	root=$1
	if(~ $root /tmp/9social/perf /tmp/9social/perf/)
		fail 'refusing perf root: '^$root
	if(! ~ $root /tmp/9social/perf/*)
		fail 'perf root must be under /tmp/9social/perf: '^$root
	if(~ $root */../* */.. ../* ..)
		fail 'perf root must not contain ..: '^$root
}

fn countindexposts {
	dir=$1
	if(test -d $dir)
		ls -p $dir >[2]/dev/null | wc -l
	if not
		echo 0
}

fn profileuuid {
	awk -F ': ' '$1=="id" { split($2, p, ":"); print p[3]; exit }' $home/lib/9social/self/profile
}

fn now {
	date -u -f 'YYYY-MM-DDThh:mm:ss[Z]'
}

fn makepost {
	file=$1
	title=$2
	body=$3
	postuuid=`{9social/lib/id/uuid}
	if(! ~ $status '' || ! ~ $#postuuid 1)
		fail 'cannot create post uuid'
	{
		echo 'id: 9social:post:'^$useruuid^':'^$postuuid
		echo 'author: '^$user
		echo 'date: '^`{now}
		echo 'title: '^$title
		echo
		echo $body
	} >$file || fail 'cannot write post: '^$file
}

fn gitcommit {
	msg=$1
	shift
	if(! git/add $* >$log.add.out >[2]$log.add.err)
		fail 'git add failed: '^`{cat $log.add.err}
	if(! git/commit -m $msg $* >$log.commit.out >[2]$log.commit.err)
		fail 'git commit failed: '^`{cat $log.commit.err}
}

fn timedupdate {
	label=$1
	if(! ~ $#2 0)
		note=$2
	if not
		note=()
	echo
	echo 'case: '^$label
	if(! ~ $#note 0)
		echo 'note: '^$note
	echo 'command: 9social/lib/index/update'
	echo 'time:'
	time 9social/lib/index/update
	st=$status
	if(! ~ $st '')
		fail 'index/update failed for '^$label^': '^$st
	indexed=`{countindexposts $home/lib/9social/index/posts}
	echo 'indexed posts: '^$indexed
}

if(! ~ $#* 2)
	usage

root=$1
simuser=$2
checkroot $root

if(! test -f $root/.9social-perf-root)
	fail 'missing perf root marker: '^$root^'/.9social-perf-root'

simhome=$root^/homes/^$simuser
if(! test -d $simhome/lib/9social)
	fail 'simulated 9social home not found: '^$simhome^'/lib/9social'

bind -b $repo/bin /bin || fail 'cannot bind repo bin'
home=$simhome
user=$simuser
cd $home || fail 'cannot cd to simulated home: '^$home

self=$home/lib/9social/self
if(! test -d $self/.git)
	fail 'self repository is not a git repository: '^$self
if(! test -f $self/profile)
	fail 'self profile not found: '^$self^'/profile'

useruuid=`{profileuuid}
if(! ~ $#useruuid 1)
	fail 'cannot read profile user uuid'

mkdir -p $root/logs || fail 'cannot create logs directory'
log=$root/logs/index-update.^$pid

prefix=posts/perf-index-update-^$pid
addfiles=()

cd $self || fail 'cannot cd to self repository: '^$self

echo 'root: '^$root
echo 'user: '^$user
echo 'home: '^$home
echo 'self: '^$self
echo 'add count: '^$addcount
echo 'mutation: this script removes the simulated user index and commits perf posts in self'

rm -rf $home/lib/9social/index || fail 'cannot remove existing index'
timedupdate 'no index'

timedupdate 'unchanged after state exists'

n=1
last=`{echo $addcount | awk '{print $1+1}'}
while(! ~ $n $last){
	rel=$prefix^-add-^$n
	makepost $self^/^$rel 'Perf index update add '^$n 'Committed addition for index/update perf.'
	addfiles=($addfiles $rel)
	n=`{echo $n | awk '{print $1+1}'}
}
gitcommit 'perf index update additions' $addfiles
timedupdate 'committed additions'

modify=$addfiles(1)
{
	echo
	echo 'Modified for index/update fallback perf.'
} >>$self^/^$modify || fail 'cannot modify post: '^$modify
gitcommit 'perf index update modification' $modify
timedupdate 'committed modification' 'fallback rebuild expected'

delete=$addfiles(2)
if(! git/rm $delete >$log.rm.out >[2]$log.rm.err)
	fail 'git rm failed: '^$delete^' '^`{cat $log.rm.err}
if(! rm $self^/^$delete)
	fail 'remove failed: '^$delete
if(! git/commit -m 'perf index update deletion' $delete >$log.delete-commit.out >[2]$log.delete-commit.err)
	fail 'git delete commit failed: '^`{cat $log.delete-commit.err}
timedupdate 'committed deletion' 'fallback rebuild expected'

exit ''
