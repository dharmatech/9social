#!/bin/rc
rfork en
repo=`{echo $0 | sed 's;/tests/perf/[^/]*$;;'}
repo=`{cd $repo && pwd}

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: tests/perf/shell-as.rc <root> <user> [command ...]' >[1=2]
	exit usage
}

fn checkroot {
	root=$1
	if(~ $root /tmp/9social/perf /tmp/9social/perf/)
		fail 'refusing perf root: '^$root
	if(! ~ $root /tmp/9social/perf/*)
		fail 'perf root must be under /tmp/9social/perf: '^$root
	if(~ $root */../* */.. ../* ..)
		fail 'perf root must not contain ..: '^$root
}

if(~ $#* 0 1)
	usage

root=$1
simuser=$2
shift
shift

checkroot $root
simhome=$root^/homes/^$simuser
if(! test -d $simhome/lib/9social)
	fail 'simulated 9social home not found: '^$simhome^'/lib/9social'

bind -b $repo/bin /bin || fail 'cannot bind repo bin'
home=$simhome
user=$simuser
cd $home || fail 'cannot cd to simulated home: '^$home

echo '9social perf shell'
echo 'root: '^$root
echo 'user: '^$user
echo 'home: '^$home

if(~ $#* 0)
	exec rc -i

exec $*
