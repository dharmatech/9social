#!/bin/rc
rfork en
repo=`{echo $0 | sed 's;/tests/[^/]*$;;'}
repo=`{cd $repo && pwd}
cmd=$repo/bin/9social/lib/new-post-draft

fn fail {
	echo FAIL: $* >[1=2]
	exit fail
}

bind -b $repo/bin /bin || fail bind

tmp=/tmp/9social
rm -rf $tmp

draft=`{$cmd}
st=$status
if(! ~ $st '') fail status $st
if(! ~ $#draft 1) fail draft-count $#draft $draft
if(! test -f $draft) fail draft-missing $draft
if(! ~ $draft /tmp/9social/9social-new-post.*) fail draft-path $draft

lines=`{sed -n '1,2p' $draft}
if(! ~ $#lines 1) fail line-count $#lines `{cat $draft}
if(! grep '^Title: $' $draft >/dev/null) fail title-line `{sed -n '1p' $draft}

$cmd extra >$tmp/out >[2]$tmp/err
st=$status
if(~ $st '') fail usage-status
grep 'usage: 9social/lib/new-post-draft' $tmp/err >/dev/null || fail usage-error `{cat $tmp/err}

echo ok
exit ''
