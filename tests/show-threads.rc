#!/bin/rc
rfork en
base=/tmp/9social-show-threads-test.$pid

fn fail {
	echo FAIL: $* >[1=2]
	exit fail
}

fn setup {
	home=$base.$1.home
	bindir=$base.$1.bin
	rm -rf $home $bindir
	mkdir -p $home/lib/9social $bindir/9social/lib/index $bindir/9social/cmd || fail mkdir
	cp /usr/glenda/src/9social/bin/9social/cmd/show-threads $bindir/9social/cmd/show-threads || fail copy-show-threads
	chmod +x $bindir/9social/cmd/show-threads
	bind -b $bindir /bin || fail bind
}

setup missing-index
>$bindir/9social/lib/index/rebuild {
	echo '#!/bin/rc'
	echo 'mkdir -p $home/lib/9social/index/posts'
	echo 'echo reindexed >$home/reindexed'
}
chmod +x $bindir/9social/lib/index/rebuild
>$bindir/9social/lib/render-threads {
	echo '#!/bin/rc'
	echo 'echo thread body'
}
chmod +x $bindir/9social/lib/render-threads
9social/cmd/show-threads >$home/out >[2]$home/err
st=$status
if(! ~ $st '') fail missing-index-status $st `{cat $home/err}
if(! test -f $home/reindexed) fail did-not-reindex
grep '^thread body$' $home/out >/dev/null || fail stdout `{cat $home/out}
if(! ~ `{cat $home/err} '') fail stderr `{cat $home/err}

setup existing-index
mkdir -p $home/lib/9social/index/posts || fail existing-index-mkdir
>$bindir/9social/lib/index/rebuild {
	echo '#!/bin/rc'
	echo 'echo should-not-reindex >$home/reindexed'
}
chmod +x $bindir/9social/lib/index/rebuild
>$bindir/9social/lib/render-threads {
	echo '#!/bin/rc'
	echo 'echo existing thread body'
}
chmod +x $bindir/9social/lib/render-threads
9social/cmd/show-threads >$home/out >[2]$home/err
st=$status
if(! ~ $st '') fail existing-index-status $st `{cat $home/err}
if(test -f $home/reindexed) fail reindexed-existing
grep '^existing thread body$' $home/out >/dev/null || fail existing-stdout `{cat $home/out}

setup reindex-fails
>$bindir/9social/lib/index/rebuild {
	echo '#!/bin/rc'
	echo 'exit fail'
}
chmod +x $bindir/9social/lib/index/rebuild
>$bindir/9social/lib/render-threads {
	echo '#!/bin/rc'
	echo 'echo should-not-render'
}
chmod +x $bindir/9social/lib/render-threads
9social/cmd/show-threads >$home/out >[2]$home/err
st=$status
if(~ $st '') fail reindex-fails-status
grep 'cannot build index' $home/err >/dev/null || fail reindex-fails-error `{cat $home/err}
if(grep 'should-not-render' $home/out >/dev/null) fail rendered-after-reindex-fail

setup usage
9social/cmd/show-threads extra >$home/out >[2]$home/err
st=$status
if(~ $st '') fail usage-status
grep 'usage: 9social/cmd/show-threads' $home/err >/dev/null || fail usage-error `{cat $home/err}

rm -rf $base.*
echo ok
exit ''
