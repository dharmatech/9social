#!/bin/rc
rfork en
repo=`{echo $0 | sed 's;/tests/[^/]*$;;'}
repo=`{cd $repo && pwd}
root=/tmp/9social-workflow.$pid
verbose=0

fn fail {
	echo FAIL: $* >[1=2]
	echo root: $root >[1=2]
	exit fail
}

fn usage {
	echo 'usage: tests/workflow.rc [-v]' >[1=2]
	exit usage
}

fn say {
	if(~ $verbose 1)
		echo $*
}

fn showfile {
	if(~ $verbose 1 && test -s $1)
		cat $1
}

fn showcmd {
	if(~ $verbose 1){
		u=$1
		shift
		echo
		echo '% '^$u^': '^$"*
	}
}

fn asuser {
	u=$1
	shift
	home=$root/homes/$u user=$u $*
}

fn mkremote {
	u=$1
	remote=$root/remotes/$u
	seed=$root/seeds/$u
	mkdir -p $remote $seed || fail $u remote-mkdir
	@{cd $remote && git/init . >/dev/null >[2]/dev/null} || fail $u remote-git-init
	@{cd $seed && git/init . >/dev/null >[2]/dev/null} || fail $u seed-git-init
	echo $u >$seed/README.md || fail $u seed-readme
	@{cd $seed && git/add README.md && git/commit -m init README.md >/dev/null >[2]/dev/null} || fail $u seed-git-commit
	@{cd $seed && git/push -u $remote >/dev/null >[2]/dev/null} || fail $u seed-git-push
	say 'remote '^$u^': '^$remote
}

fn inituser {
	u=$1
	mkdir -p $root/homes/$u || fail $u home-mkdir
	showcmd $u 9social/init-self $root/remotes/$u
	asuser $u 9social/init-self $root/remotes/$u >$root/$u.init.out >[2]$root/$u.init.err
	st=$status
	if(! ~ $st '') fail $u init-self $st `{cat $root/$u.init.err}
	showfile $root/$u.init.out
	showfile $root/$u.init.err
	if(~ $verbose 1){
		echo profile:
		cat $root/homes/$u/lib/9social/self/profile
	}
}

fn assertgrep {
	pat=$1
	file=$2
	msg=$3
	grep $pat $file >/dev/null || fail $msg `{cat $file}
}

if(~ $#* 0)
	verbose=0
if not if(~ $#* 1 && ~ $1 -v)
	verbose=1
if not
	usage

rm -rf $root
mkdir -p $root/remotes $root/seeds $root/homes || fail mkdir-root
bind -b $repo/bin /bin || fail bind

say 'test root: '^$root
say
say 'creating README-only local repositories'
mkremote rms
mkremote linus
mkremote alan

say
say 'initializing simulated users'
inituser rms
inituser linus
inituser alan

showcmd rms 9social/new-post -
{
	echo 'Title: Free Software and Emacs'
	echo
	echo 'Software should respect the user''s freedom.'
	echo 'Emacs remains a good place to build extensible tools.'
} | asuser rms 9social/new-post - >$root/rms.new-post.out >[2]$root/rms.new-post.err
st=$status
if(! ~ $st '') fail rms new-post $st `{cat $root/rms.new-post.err}
assertgrep '^posted: posts/' $root/rms.new-post.out rms-new-post-output
showfile $root/rms.new-post.out
showfile $root/rms.new-post.err
if(~ $verbose 1){
	post=`{walk $root/homes/rms/lib/9social/self/posts | grep '/posts/' | grep -v '/posts$' | grep -v '/\.keep$'}
	echo 'created post: '^$post
	cat $post
}

showcmd rms 9social/push
asuser rms 9social/push >$root/rms.push.out >[2]$root/rms.push.err
st=$status
if(! ~ $st '') fail rms push $st `{cat $root/rms.push.err}
showfile $root/rms.push.out
showfile $root/rms.push.err

showcmd linus 9social/follow $root/remotes/rms
asuser linus 9social/follow $root/remotes/rms >$root/linus.follow.out >[2]$root/linus.follow.err
st=$status
if(! ~ $st '') fail linus follow $st `{cat $root/linus.follow.err}
showfile $root/linus.follow.out
showfile $root/linus.follow.err
if(~ $verbose 1){
	echo 'linus following:'
	cat $root/homes/linus/lib/9social/self/following
}

showcmd linus 9social/refresh
asuser linus 9social/refresh >$root/linus.refresh.out >[2]$root/linus.refresh.err
st=$status
if(! ~ $st '') fail linus refresh $st `{cat $root/linus.refresh.err}
assertgrep '^clone '^$root^'/remotes/rms$' $root/linus.refresh.out linus-refresh-clone
showfile $root/linus.refresh.out
showfile $root/linus.refresh.err

showcmd linus 9social/timeline
asuser linus 9social/timeline >$root/linus.timeline.out >[2]$root/linus.timeline.err
st=$status
if(! ~ $st '') fail linus timeline $st `{cat $root/linus.timeline.err}
assertgrep '^.*  rms$' $root/linus.timeline.out linus-timeline-author
assertgrep '^title: Free Software and Emacs$' $root/linus.timeline.out linus-timeline-title
assertgrep 'Software should respect the user''s freedom\.' $root/linus.timeline.out linus-timeline-body
assertgrep $root^'/homes/linus/lib/9social/feeds/rms/posts/' $root/linus.timeline.out linus-timeline-path
showfile $root/linus.timeline.out
showfile $root/linus.timeline.err

rms_post=`{walk $root/homes/linus/lib/9social/feeds/rms/posts | grep '/posts/' | grep -v '/posts$' | grep -v '/\.keep$'}
if(! ~ $#rms_post 1)
	fail linus-rms-post-path $#rms_post

showcmd linus 9social/reply $rms_post
{
	echo 'A practical kernel also needs good tools around it.'
} | asuser linus 9social/reply $rms_post >$root/linus.reply.out >[2]$root/linus.reply.err
st=$status
if(! ~ $st '') fail linus reply $st `{cat $root/linus.reply.err}
assertgrep '^posted: posts/' $root/linus.reply.out linus-reply-output
showfile $root/linus.reply.out
showfile $root/linus.reply.err
if(~ $verbose 1){
	replypost=`{walk $root/homes/linus/lib/9social/self/posts | grep '/posts/' | grep -v '/posts$' | grep -v '/\.keep$'}
	echo 'created reply: '^$replypost
	cat $replypost
}

showcmd linus 9social/push
asuser linus 9social/push >$root/linus.push.out >[2]$root/linus.push.err
st=$status
if(! ~ $st '') fail linus push $st `{cat $root/linus.push.err}
showfile $root/linus.push.out
showfile $root/linus.push.err

showcmd alan 9social/follow $root/remotes/rms
asuser alan 9social/follow $root/remotes/rms >$root/alan.follow-rms.out >[2]$root/alan.follow-rms.err
st=$status
if(! ~ $st '') fail alan follow-rms $st `{cat $root/alan.follow-rms.err}
showfile $root/alan.follow-rms.out
showfile $root/alan.follow-rms.err

showcmd alan 9social/refresh
asuser alan 9social/refresh >$root/alan.refresh-rms.out >[2]$root/alan.refresh-rms.err
st=$status
if(! ~ $st '') fail alan refresh-rms $st `{cat $root/alan.refresh-rms.err}
showfile $root/alan.refresh-rms.out
showfile $root/alan.refresh-rms.err

alan_rms_post=`{walk $root/homes/alan/lib/9social/feeds/rms/posts | grep '/posts/' | grep -v '/posts$' | grep -v '/\.keep$'}
if(! ~ $#alan_rms_post 1)
	fail alan-rms-post-path $#alan_rms_post
rms_target=`{asuser alan 9social/lib/post-id $alan_rms_post}
if(! ~ $#rms_target 1)
	fail alan-rms-post-id $#rms_target

showcmd alan 9social/like $alan_rms_post
asuser alan 9social/like $alan_rms_post >$root/alan.like.out >[2]$root/alan.like.err
st=$status
if(! ~ $st '') fail alan like $st `{cat $root/alan.like.err}
assertgrep '^liked: '^$rms_target^'$' $root/alan.like.out alan-like-output
showfile $root/alan.like.out
showfile $root/alan.like.err
if(~ $verbose 1){
	likepost=`{walk $root/homes/alan/lib/9social/self/posts | grep '/posts/' | grep -v '/posts$' | grep -v '/\.keep$'}
	echo 'created like: '^$likepost
	cat $likepost
}

showcmd alan 9social/push
asuser alan 9social/push >$root/alan.push.out >[2]$root/alan.push.err
st=$status
if(! ~ $st '') fail alan push $st `{cat $root/alan.push.err}
showfile $root/alan.push.out
showfile $root/alan.push.err

showcmd rms 9social/follow $root/remotes/alan
asuser rms 9social/follow $root/remotes/alan >$root/rms.follow-alan.out >[2]$root/rms.follow-alan.err
st=$status
if(! ~ $st '') fail rms follow-alan $st `{cat $root/rms.follow-alan.err}
showfile $root/rms.follow-alan.out
showfile $root/rms.follow-alan.err

showcmd rms 9social/refresh
asuser rms 9social/refresh >$root/rms.refresh-alan.out >[2]$root/rms.refresh-alan.err
st=$status
if(! ~ $st '') fail rms refresh-alan $st `{cat $root/rms.refresh-alan.err}
showfile $root/rms.refresh-alan.out
showfile $root/rms.refresh-alan.err

encoded_rms_target=`{asuser rms 9social/lib/encode-id $rms_target}
if(! ~ $#encoded_rms_target 1)
	fail rms-encode-like-target $#encoded_rms_target
likes=$root/homes/rms/lib/9social/index/targets/$encoded_rms_target/likes
if(! test -d $likes)
	fail rms-like-index-missing $likes
likecount=`{ls -p $likes | wc -l}
if(! ~ $likecount 1)
	fail rms-like-index-count $likecount

showcmd rms 9social/follow $root/remotes/linus
asuser rms 9social/follow $root/remotes/linus >$root/rms.follow.out >[2]$root/rms.follow.err
st=$status
if(! ~ $st '') fail rms follow $st `{cat $root/rms.follow.err}
showfile $root/rms.follow.out
showfile $root/rms.follow.err
if(~ $verbose 1){
	echo 'rms following:'
	cat $root/homes/rms/lib/9social/self/following
}

showcmd rms 9social/refresh
asuser rms 9social/refresh >$root/rms.refresh.out >[2]$root/rms.refresh.err
st=$status
if(! ~ $st '') fail rms refresh $st `{cat $root/rms.refresh.err}
assertgrep '^clone '^$root^'/remotes/linus$' $root/rms.refresh.out rms-refresh-clone
showfile $root/rms.refresh.out
showfile $root/rms.refresh.err

showcmd rms 9social/timeline
asuser rms 9social/timeline >$root/rms.timeline.out >[2]$root/rms.timeline.err
st=$status
if(! ~ $st '') fail rms timeline $st `{cat $root/rms.timeline.err}
assertgrep '^.*  linus$' $root/rms.timeline.out rms-timeline-reply-author
assertgrep '^title: Re: Free Software and Emacs$' $root/rms.timeline.out rms-timeline-reply-title
assertgrep 'A practical kernel also needs good tools around it\.' $root/rms.timeline.out rms-timeline-reply-body
assertgrep $root^'/homes/rms/lib/9social/feeds/linus/posts/' $root/rms.timeline.out rms-timeline-reply-path
showfile $root/rms.timeline.out
showfile $root/rms.timeline.err

rm -rf $root
echo ok
exit ''
