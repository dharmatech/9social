#!/bin/rc
rfork en
repo=`{echo $0 | sed 's;/tests/[^/]*$;;'}
cmd=$repo/bin/9social/Menu

fn fail {
	echo FAIL: $* >[1=2]
	exit fail
}

home=/tmp/9social-Menu-test.$pid
rm -rf $home
mkdir -p $home || fail mkdir

$cmd >$home/out >[2]$home/err
st=$status
if(~ $st '') fail noacme-status
grep 'acme window system not available' $home/err >/dev/null || fail noacme-error

$cmd extra >$home/out >[2]$home/err
st=$status
if(~ $st '') fail usage-status
grep 'usage: 9social/Menu' $home/err >/dev/null || fail usage-error

rm -rf $home
echo ok
exit ''
