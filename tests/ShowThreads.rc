#!/bin/rc
rfork e
repo=`{echo $0 | sed 's;/tests/[^/]*$;;'}
cmd=$repo/bin/9social/ShowThreads
base=/tmp/9social-ShowThreads-test.$pid

fn fail {
	echo FAIL: $* >[1=2]
	exit fail
}

home=$base.home
bindir=$base/bin
rm -rf $base.* $bindir
mkdir -p $home/tmp $bindir/lib || fail mkdir

testcmd=$bindir/ShowThreads
cp $cmd $testcmd || fail copy-command
chmod +x $testcmd

>$bindir/reindex {
	echo '#!/bin/rc'
	echo 'mkdir -p $home/lib/9social/index/posts'
	echo 'echo reindexed >$home/reindexed'
}
chmod +x $bindir/reindex

>$bindir/lib/render-threads {
	echo '#!/bin/rc'
	echo 'echo thread body'
}
chmod +x $bindir/lib/render-threads

>$bindir/lib/open-file-window {
	echo '#!/bin/rc'
	echo 'echo $1 >$home/opened'
	echo 'echo $2 >$home/tag'
	echo 'cat $1 >$home/body'
}
chmod +x $bindir/lib/open-file-window

$testcmd >$home/out >[2]$home/err
st=$status
if(! ~ $st '') fail status $st `{cat $home/err}
if(! test -f $home/reindexed) fail did-not-reindex
if(! test -f $home/opened) fail did-not-open
if(! grep '^thread body$' $home/body >/dev/null) fail body `{cat $home/body}
if(! grep '^ | 9social/open-post$' $home/tag >/dev/null) fail tag `{cat $home/tag}
opened=`{cat $home/opened}
if(! ~ $opened $home/tmp/9social-threads.*) fail opened-path $opened

$testcmd extra >$home/out >[2]$home/err
st=$status
if(~ $st '') fail usage-status
grep 'usage: 9social/ShowThreads' $home/err >/dev/null || fail usage-error `{cat $home/err}

rm -rf $base.* $bindir
echo ok
exit ''
