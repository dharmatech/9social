#!/bin/rc
rfork en
mkdir -p /tmp/9social/tests
repo=`{echo $0 | sed 's;/tests/[^/]*$;;'}
base=/tmp/9social/tests/ShowThreads.$pid

fn fail {
	echo FAIL: $* >[1=2]
	exit fail
}

home=$base.home
bindir=$base/bin
rm -rf $base.* $bindir
mkdir -p $home/tmp $bindir/9social/lib/acme $bindir/9social/cmd || fail mkdir

cp $repo/bin/9social/ShowThreads $bindir/9social/ShowThreads || fail copy-command
chmod +x $bindir/9social/ShowThreads
cp $repo/bin/9social/lib/mk-temp-file $bindir/9social/lib/mk-temp-file || fail copy-mk-temp-file
chmod +x $bindir/9social/lib/mk-temp-file

>$bindir/9social/cmd/show-threads {
	echo '#!/bin/rc'
	echo 'echo thread body'
}
chmod +x $bindir/9social/cmd/show-threads

>$bindir/9social/lib/acme/open-file-window {
	echo '#!/bin/rc'
	echo 'echo $1 >$home/opened'
	echo 'echo $2 >$home/tag'
	echo 'cat $1 >$home/body'
}
chmod +x $bindir/9social/lib/acme/open-file-window

bind -b $bindir /bin || fail bind
9social/ShowThreads >$home/out >[2]$home/err
st=$status
if(! ~ $st '') fail status $st `{cat $home/err}
if(! test -f $home/opened) fail did-not-open
if(! grep '^thread body$' $home/body >/dev/null) fail body `{cat $home/body}
if(! grep '^ | 9social/OpenPost$' $home/tag >/dev/null) fail tag `{cat $home/tag}
opened=`{cat $home/opened}
if(! ~ $opened /tmp/9social/threads.*) fail opened-path $opened

9social/ShowThreads extra >$home/out >[2]$home/err
st=$status
if(~ $st '') fail usage-status
grep 'usage: 9social/ShowThreads' $home/err >/dev/null || fail usage-error `{cat $home/err}

rm -rf $base.* $bindir
echo ok
exit ''
