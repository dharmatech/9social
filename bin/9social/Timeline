#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ~ $#timelinefile 0)
		echo 'timeline: '^$timelinefile >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/Timeline' >[1=2]
	exit usage
}

if(! ~ $#* 0)
	usage

if(! test -f /mnt/wsys/index){
	echo 'Timeline: acme window system not available' >[1=2]
	echo 'Timeline: run from acme, or use 9social/timeline' >[1=2]
	exit 'no acme'
}

timeline=9social/timeline
open_file_window=9social/lib/open-file-window
if(~ $0 */Timeline){
	timeline=`{echo $0 | sed 's;/Timeline$;/timeline;'}
	open_file_window=`{echo $0 | sed 's;/Timeline$;/lib/open-file-window;'}
}

tmpdir=$home^/tmp
if(! test -d $tmpdir)
	mkdir $tmpdir >[2]/dev/null
if(! test -d $tmpdir)
	tmpdir=/tmp
if(! test -d $tmpdir)
	fail 'cannot use timeline directory'

base=$tmpdir^/9social-timeline.^$pid
timelinefile=$base
n=2
while(test -e $timelinefile){
	timelinefile=$base^.^$n
	n=`{echo $n | awk '{print $1+1}'}
}
if(test -e $timelinefile)
	fail 'timeline already exists: '^$timelinefile

$timeline >$timelinefile
st=$status
if(! ~ $st '')
	fail 'cannot create timeline'
if(! test -f $timelinefile)
	fail 'cannot create timeline'

if(! $open_file_window $timelinefile ' | 9social/OpenPost')
	exit $status

exit ''
