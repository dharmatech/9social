#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ‾ $#timelinefile 0)
		echo 'timeline: '^$timelinefile >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/Timeline' >[1=2]
	exit usage
}

if(! ‾ $#* 0)
	usage

if(! test -f /mnt/wsys/index){
	echo 'Timeline: acme window system not available' >[1=2]
	echo 'Timeline: run from acme, or use 9social/cmd/timeline' >[1=2]
	exit 'no acme'
}

timelinefile=`{9social/lib/mk-temp-file timeline} ||
	fail 'cannot create timeline temp file'

9social/cmd/timeline >$timelinefile ||
	fail 'cannot create timeline'
if(! test -f $timelinefile)
	fail 'cannot create timeline'

if(! 9social/lib/open-file-window $timelinefile ' | 9social/OpenPost')
	exit $status

exit ''
