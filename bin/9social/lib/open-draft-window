#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ‾ $#draft 0)
		echo 'draft: '^$draft >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/lib/open-draft-window <draft>' >[1=2]
	exit usage
}

if(! ‾ $#* 1)
	usage

draft=$1
if(! test -f $draft)
	fail 'draft file not found: '^$draft

open_file_window=9social/lib/open-file-window
if(‾ $0 */lib/open-draft-window)
	open_file_window=`{echo $0 | sed 's;/open-draft-window$;/open-file-window;'}

$open_file_window $draft ' | 9social/Publish 9social/Cancel'
st=$status
if(! ‾ $st '')
	exit $st

exit ''
