#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ‾ $#draft 0)
		echo 'draft: '^$draft >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/lib/open-draft-window <draft>' >[1=2]
	exit usage
}

if(! ‾ $#* 1)
	usage

draft=$1

if(! test -f $draft)
	fail 'draft file not found: '^$draft
if(! test -f /mnt/wsys/index)
	fail 'acme window system not available'

newctl=/mnt/wsys/new/ctl

winid=`{cat $newctl >[2]/dev/null | awk '{print $1; exit}'}
if(! ‾ $status '')
	fail 'cannot create acme window'
if(! ‾ $#winid 1)
	fail 'cannot create acme window'

winctl=/mnt/wsys/$winid/ctl
wintag=/mnt/wsys/$winid/tag

if(! echo name $draft >$winctl)
	fail 'cannot name acme window'
if(! echo get >$winctl)
	fail 'cannot load acme body'
if(! echo ' | 9social/Publish 9social/Cancel' >$wintag)
	fail 'cannot write acme tag'
if(! echo clean >$winctl)
	fail 'cannot mark acme window clean'

exit ''
