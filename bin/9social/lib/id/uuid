#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

uuid=`{dd -if /dev/random -bs 16 -count 1 -quiet 1 >[2]/dev/null | xd -1x | awk '
	function variant(b, h, l) {
		h = substr(b, 1, 1)
		l = substr(b, 2, 1)
		if(h ~ /[048c]/) return "8" l
		if(h ~ /[159d]/) return "9" l
		if(h ~ /[26ae]/) return "a" l
		return "b" l
	}
	NR == 1 {
		b6 = "4" substr($8, 2, 1)
		b8 = variant($10)
		printf "%s%s%s%s-%s%s-%s%s-%s%s-%s%s%s%s%s%s\n",
			$2, $3, $4, $5,
			$6, $7,
			b6, $9,
			b8, $11,
			$12, $13, $14, $15, $16, $17
	}
'}

if(! ~ $#uuid 1)
	fail 'cannot generate uuid'
if(! echo $uuid | /bin/9social/lib/id/valid-uuid-v4.awk)
	fail 'cannot generate uuid'

echo $uuid
