#!/bin/rc

fn cleanup {
	if(! ~ $#titlefile 0)
		rm -f $titlefile $rawbody $bodyfile $slugsource >[2]/dev/null
}

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ~ $#draft 0)
		echo 'draft: '^$draft >[1=2]
	cleanup
	exit $1
}

fn usage {
	echo 'usage: 9social/lib/publish-draft <draft>' >[1=2]
	exit usage
}

fn validmeta {
	awk -F': ' '
		function trim(s){
			gsub(/^[ \t]+/, "", s)
			gsub(/[ \t]+$/, "", s)
			return s
		}
		function ishex(s){
			return s ~ /^[0-9a-fA-F]+$/
		}
		function isuuid(s, p){
			if(split(s, p, "-") != 5)
				return 0
			return length(p[1]) == 8 && ishex(p[1]) && \
				length(p[2]) == 4 && ishex(p[2]) && \
				length(p[3]) == 4 && ishex(p[3]) && \
				length(p[4]) == 4 && ishex(p[4]) && \
				length(p[5]) == 12 && ishex(p[5])
		}
		function ispostid(s, p){
			if(split(s, p, ":") != 4)
				return 0
			return p[1] == "9social" && p[2] == "post" && isuuid(p[3]) && isuuid(p[4])
		}
		function failmeta(msg){
			print "publish-draft: bad metadata: " msg > "/fd/2"
			failed = 1
			exit 1
		}
		index($0, ": ") == 0 { failmeta("malformed field") }
		{
			key=$1
			val=trim(substr($0, index($0, ": ")+2))
			if(key == "type"){
				if(type != "") failmeta("duplicate type")
				type=val
			} else if(key == "target"){
				if(target != "") failmeta("duplicate target")
				target=val
			} else
				failmeta("unknown field " key)
		}
		END {
			if(failed)
				exit 1
			if(type == "") failmeta("missing type")
			if(target == "") failmeta("missing target")
			if(type != "reply") failmeta("unsupported type")
			if(!ispostid(target)) failmeta("malformed target")
			print type
			print target
		}
	' $1
}

if(! ~ $#* 1)
	usage

draft=$1
if(! test -f $draft)
	fail 'draft file not found: '^$draft

social=$home^/lib/9social
self=$social^/self
profile=$self^/profile
posts=$self^/posts
uuidcmd=9social/uuid
if(~ $0 */lib/publish-draft)
	uuidcmd=`{echo $0 | sed 's;/lib/publish-draft$;/uuid;'}

titlefile=$draft^.title
rawbody=$draft^.body
bodyfile=$draft^.body.trim
slugsource=$draft^.slugsource
sidecar=$draft^.meta

if(! test -d $self)
	fail $self^' does not exist'
if(! test -e $self/.git)
	fail $self^' is not a Git repository'
if(! test -f $profile)
	fail 'bad profile: '^$profile

profiledata=`{9social/lib/valid-profile.awk $profile}
if(! ~ $status '')
	fail 'bad profile: '^$profile
if(! ~ $#profiledata 2)
	fail 'bad profile: '^$profile
useruuid=$profiledata(1)
author=$profiledata(2)

metatype=()
metatarget=()
if(test -f $sidecar){
	metadata=`{validmeta $sidecar}
	if(! ~ $status '')
		fail 'bad draft metadata: '^$sidecar
	if(! ~ $#metadata 2)
		fail 'bad draft metadata: '^$sidecar
	metatype=$metadata(1)
	metatarget=$metadata(2)
}

if(! test -d $posts){
	if(! mkdir $posts >[2]/dev/null)
		fail 'cannot create posts'
}

if(! awk -v 'titlefile='$titlefile -v 'bodyfile='$rawbody '
	function trim(s){
		gsub(/^[ \t]+/, "", s)
		gsub(/[ \t]+$/, "", s)
		return s
	}
	NR == 1 && /^Title:/ {
		hastitle=1
		print trim(substr($0, 7)) > titlefile
		next
	}
	NR == 1 {
		print > bodyfile
		next
	}
	hastitle && NR == 2 {
		sawsecond=1
		if($0 !~ /^[ \t]*$/)
			exit 2
		next
	}
	{
		print > bodyfile
	}
	END {
		if(hastitle && !sawsecond)
			exit 2
	}
' $draft)
	fail 'bad draft: Title line must be followed by a blank line'

awk '
	{
		line[++n]=$0
		if($0 !~ /^[ \t]*$/)
			last=n
	}
	END {
		first=1
		while(first <= last && line[first] ~ /^[ \t]*$/)
			first++
		if(last < first)
			exit 1
		for(i=first; i<=last; i++)
			print line[i]
	}
' $rawbody >$bodyfile
if(! ~ $status ''){
	cleanup
	exit empty
}

if(test -s $titlefile)
	cp $titlefile $slugsource
if not
	awk '$0 !~ /^[ \t]*$/ { print; exit }' $bodyfile >$slugsource

slug=`{awk '
	{
		s=tolower($0)
		gsub(/[ \t]+/, "-", s)
		gsub(/[^a-z0-9-]/, "", s)
		gsub(/-+/, "-", s)
		gsub(/^-+/, "", s)
		gsub(/-+$/, "", s)
		s=substr(s, 1, 48)
		gsub(/-+$/, "", s)
		if(s == "")
			s="post"
		print s
		exit
	}
' $slugsource}
if(! ~ $#slug 1)
	slug=post
if(~ $slug '')
	slug=post

date=`{date -u -f 'YYYY-MM-DDThh:mm:ss[Z]'}
if(! ~ $#date 1)
	fail 'cannot generate date'
day=`{echo $date | sed 's/T.*//'}
if(! ~ $#day 1)
	fail 'cannot generate filename'

postuuid=`{$uuidcmd}
if(! ~ $#postuuid 1)
	fail 'cannot generate uuid'
postid=9social:post:^$useruuid^:^$postuuid

base=$day^'-'^$slug
relpost=posts^/$base
post=$posts^/$base
n=2
while(test -e $post){
	relpost=posts^/$base^'-'^$n
	post=$posts^/$base^'-'^$n
	n=`{echo $n | awk '{print $1+1}'}
}

if(test -e $post)
	fail 'post already exists: '^$relpost

{
	echo 'id: '^$postid
	echo 'author: '^$author
	echo 'date: '^$date
	if(! ~ $#metatype 0){
		echo 'type: '^$metatype
		echo 'target: '^$metatarget
	}
	if(test -s $titlefile){
		title=`{cat $titlefile}
		echo 'title:' $title
	}
	echo
	cat $bodyfile
} >$post
if(! ~ $status '')
	fail 'cannot write post: '^$relpost

if(! @{cd $self && git/add $relpost})
	fail 'git add failed'
if(! @{cd $self && git/commit -m 'post: '^$postid $relpost})
	fail 'git commit failed'

rm -f $draft $sidecar >[2]/dev/null
cleanup

echo 'posted: '^$relpost
exit ''
