#!/bin/rc
# Convert an absolute self post path to a path relative to
# `$home/lib/9social/self`.
#
# Accepts only files below `$home/lib/9social/self/posts/`, rejects empty
# or parent-directory path components, and prints values such as
# `posts/2026-05-02-example`.

fn usage {
	echo 'usage: 9social/lib/post/self-path <post-path>' >[1=2]
	exit usage
}

if(! ~ $#* 1)
	usage

awk -v 'self='^$home^/lib/9social/self -v 'post='^$1 '
	BEGIN {
		prefix = self "/posts/"
		if(index(post, prefix) != 1 || length(post) <= length(prefix))
			exit 1
		rel = substr(post, length(self) + 2)
		n = split(rel, part, "/")
		for(i = 1; i <= n; i++)
			if(part[i] == "" || part[i] == "..")
				exit 1
		print rel
	}
'
