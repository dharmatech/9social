#!/bin/rc
# Resolve a canonical post ID to a local post file path.
#
# Looks up the encoded post ID in `$home/lib/9social/index/posts`,
# reads the indexed file path, verifies that the post file still exists,
# and prints that path.

if(! ~ $#* 1){
	echo 'usage: 9social/lib/post/path <post-id>' >[1=2]
	exit usage
}

postid=$1
encoded=`{9social/lib/id/encode.awk $postid >[2]/dev/null}
if(! ~ $status ''){
	echo 'post-path: malformed post id' >[1=2]
	exit 'malformed post id'
}

entry=$home^/lib/9social/index/posts/^$encoded
if(! test -f $entry){
	echo 'post not found locally: '^$postid >[1=2]
	exit 'post not found'
}

postpath=`{sed -n '1p' $entry}
if(~ $#postpath 0){
	echo 'post-path: empty index entry: '^$entry >[1=2]
	exit 'empty index entry'
}
if(! test -f $postpath){
	echo 'post-path: indexed path missing: '^$postpath >[1=2]
	exit 'indexed path missing'
}

echo $postpath
exit ''
