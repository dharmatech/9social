#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/lib/acme/current-line' >[1=2]
	exit usage
}

if(! ~ $#* 0)
	usage
if(~ $#winid 0 || ~ $winid '')
	fail 'missing winid'
if(! test -d /mnt/acme/$winid)
	fail 'acme window not found: '^$winid

pos=`{9social/lib/acme/cursor-position}
st=$status
if(! ~ $st '' || ! ~ $#pos 1)
	fail 'cannot read cursor position'

@{
	cd /mnt/acme/$winid || exit 'no window'
	awk -v 'pos='$pos '
		BEGIN { start = 0 }
		{
			end = start + length($0)
			if(pos >= start && pos <= end){
				print
				found = 1
				exit
			}
			start = end + 1
		}
		END {
			if(!found)
				exit 1
		}
	' body
}
st=$status
if(! ~ $st '')
	fail 'cannot read current line'

exit ''
