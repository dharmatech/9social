#!/bin/rc

fn fail {
	echo $0^': '^$* >[1=2]
	cleanup
	exit $1
}

fn usage {
	echo 'usage: 9social/lib/render/threads' >[1=2]
	exit usage
}

if(! ~ $#* 0)
	usage

social=$home^/lib/9social
index=$social^/index
tmpdir=/tmp/9social
records=$tmpdir^/render-threads.^$pid

fn cleanup {
	rm -f $records
}

if(! test -d $index/posts)
	fail 'index not found' 'no index'

if(! mkdir -p $tmpdir)
	fail 'cannot create temp directory' $tmpdir

ls -p $index/posts >[2]/dev/null | sort | 9social/lib/render/thread-records-from-index.awk $index/posts >$records
st=$status
if(! ~ $st ''){
	cleanup
	exit $st
}

9social/lib/render/thread-records.awk $records
st=$status
cleanup
exit $st
