#!/bin/awk -f /bin/9social/lib/id.awk -f

function fail(){ exit 1 }
function trim(s){
	gsub(/^[ \t]+/, "", s)
	gsub(/[ \t]+$/, "", s)
	return s
}
BEGIN {
	if(ARGC != 2)
		fail()
	datepat = "^[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]T[0-9][0-9]:[0-9][0-9]:[0-9][0-9]Z$"
}

!body {
	if($0 == ""){
		body = 1
		next
	}
	if(index($0, ":") == 0)
		bad = 1
	key = substr($0, 1, index($0, ":") - 1)
	val = trim(substr($0, index($0, ":") + 1))
	if(key == "id"){
		id_count++
		id = val
	} else if(key == "author"){
		author_count++
		author = val
	} else if(key == "date"){
		date_count++
		date = val
	} else if(key == "title"){
		title_count++
	} else if(key == "type"){
		type_count++
		type = val
	} else if(key == "target"){
		target_count++
		target = val
	}
}

END {
	if(bad || !body)
		fail()
	if(id_count != 1 || author_count != 1 || date_count != 1)
		fail()
	if(!is_post_id(id))
		fail()
	if(author == "")
		fail()
	if(date !~ datepat)
		fail()
	if(type_count > 1 || target_count > 1)
		fail()
	if(type_count == 1 && type != "reply" && type != "like")
		fail()
	if(target_count == 1 && !is_post_id(target))
		fail()
	if(type == "reply" && target_count != 1)
		fail()
	if(type == "like" && target_count != 1)
		fail()
}
