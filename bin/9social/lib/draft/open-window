#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ‾ $#draft 0)
		echo 'draft: '^$draft >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/lib/draft/open-window <draft>' >[1=2]
	exit usage
}

if(! ‾ $#* 1) usage

draft=$1

test -f $draft || fail 'draft file not found: '^$draft

9social/lib/open-file-window $draft ' | 9social/Draft/Publish 9social/Draft/Cancel' ||
	exit $status

exit ''
