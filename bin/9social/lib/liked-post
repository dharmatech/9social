#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/lib/liked-post <post-id>' >[1=2]
	exit usage
}

fn profilename {
	awk -F': ' '
		function trim(s){
			gsub(/^[ \t]+/, "", s)
			gsub(/[ \t]+$/, "", s)
			return s
		}
		$1 == "name" && name == "" { name = trim(substr($0, index($0, ": ")+2)) }
		END { if(name != "") print name; else exit 1 }
	' $1
}

if(! ~ $#* 1)
	usage

target=$1
profile=$home^/lib/9social/self/profile
encode_id=9social/lib/encode-id
post_meta=9social/lib/post-meta
if(~ $0 */lib/liked-post){
	encode_id=`{echo $0 | sed 's;/lib/liked-post$;/lib/encode-id;'}
	post_meta=`{echo $0 | sed 's;/lib/liked-post$;/lib/post-meta;'}
}

if(! test -f $profile)
	exit 'not liked'
author=`{profilename $profile >[2]/dev/null}
if(! ~ $status '' || ! ~ $#author 1)
	exit 'not liked'

encoded=`{$encode_id $target >[2]/dev/null}
if(! ~ $status '' || ! ~ $#encoded 1)
	fail 'malformed post id: '^$target
likes=$home^/lib/9social/index/targets/^$encoded^/likes
if(! test -d $likes)
	exit 'not liked'

for(name in `{ls -p $likes >[2]/dev/null | sort}){
	like=`{cat $likes/$name >[2]/dev/null}
	if(~ $#like 1 && test -f $like){
		if($post_meta $like >[2]/dev/null | awk -F '	' -v 'target='$target -v 'author='$author '
			$1 == "type" && type == "" { type = $2 }
			$1 == "target" && liketarget == "" { liketarget = $2 }
			$1 == "author" && likeauthor == "" { likeauthor = $2 }
			END { exit !(type == "like" && liketarget == target && likeauthor == author) }
		')
			exit ''
	}
}

exit 'not liked'
