#!/bin/rc

if(! ~ $#* 0){
	echo 'usage: 9social/lib/index/rebuild' >[1=2]
	exit usage
}

social=$home^/lib/9social
index=$social^/index
tmp=$social^/index.tmp.^$pid
fn failstruct {
	echo $0^': '^$* >[1=2]
	rm -rf $tmp
	exit 'reindex failed'
}

fn indexpost {
	post=$1
	indexroot=$tmp warn=1 9social/lib/index/add-post $post
	st=$status
	if(~ $st *failed)
		failstruct 'cannot index '^$post
	if not if(! ~ $st '' *skipped)
		failstruct 'cannot index '^$post^': '^$st
}

fn scanposts {
	posts=$1
	if(test -d $posts){
		for(name in `{ls -p $posts >[2]/dev/null | sort}){
			if(! ~ $name .* && test -f $posts^/^$name)
				indexpost $posts^/^$name
		}
	}
}

rm -rf $tmp
if(! mkdir -p $tmp/posts $tmp/targets)
	failstruct 'cannot create '^$tmp

scanposts $social^/self/posts

if(test -d $social^/feeds){
	for(feed in `{ls -p $social^/feeds >[2]/dev/null | sort}){
		if(test -d $social^/feeds/^$feed)
			scanposts $social^/feeds/^$feed^/posts
	}
}

if(test -d $index){
	if(! rm -rf $index)
		failstruct 'cannot remove old index'
}
if(! mv $tmp $index)
	failstruct 'cannot install index'

exit ''
