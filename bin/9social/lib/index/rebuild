#!/bin/rc

if(! ~ $#* 0){
	echo 'usage: 9social/lib/index/rebuild' >[1=2]
	exit usage
}

social=$home^/lib/9social
index=$social^/index
tmp=$social^/index.tmp.^$pid
meta=/tmp/9social-reindex-meta.^$pid
metaerr=/tmp/9social-reindex-metaerr.^$pid
fn cleanup {
	rm -f $meta $metaerr
}

fn failstruct {
	echo $0^': '^$* >[1=2]
	rm -rf $tmp
	cleanup
	exit 'reindex failed'
}

fn warn {
	echo $0^': '^$* >[1=2]
}

fn field {
	awk -F '	' -v 'k='$1 '$1==k && value=="" { value=$2 } END { if(value != "") print value }' $meta
}

fn indexpost {
	post=$1
	skip=0
	if(! 9social/lib/post-meta $post >$meta >[2]$metaerr){
		warn 'skip post (bad format): '^$post
		rm -f $meta $metaerr
		skip=1
	}

	if(~ $skip 0){
		id=`{field id}
		if(~ $#id 0){
			warn 'skip post (missing id): '^$post
			skip=1
		}
	}
	if(~ $skip 0){
		encoded_id=`{9social/lib/encode-id $id >[2]/dev/null}
		if(! ~ $status ''){
			warn 'skip post (malformed id): '^$post
			skip=1
		}
	}
	if(~ $skip 0){
		post_index=$tmp^/posts/^$encoded_id
		if(test -f $post_index){
			old=`{cat $post_index}
			warn 'skip post (duplicate id): '^$post^' already indexed: '^$old
			skip=1
		}
	}
	if(~ $skip 0){
		if(! echo $post >$post_index)
			failstruct 'cannot write '^$post_index

		type=`{field type}
		if(! ~ $#type 0 && ~ $type reply like){
			target=`{field target}
			if(~ $#target 0){
				warn 'skip relationship (missing target): '^$post
			}
			if(! ~ $#target 0){
				target_ok=1
				encoded_target=`{9social/lib/encode-id $target >[2]/dev/null}
				if(! ~ $status ''){
					warn 'skip relationship (malformed target): '^$post
					target_ok=0
				}
				if(~ $target_ok 1){
					if(~ $type reply)
						reldir=$tmp^/targets/^$encoded_target^/replies
					if(~ $type like)
						reldir=$tmp^/targets/^$encoded_target^/likes
					if(! mkdir -p $reldir)
						failstruct 'cannot create '^$reldir
					relfile=$reldir^/^$encoded_id
					if(! echo $post >$relfile)
						failstruct 'cannot write '^$relfile
				}
			}
		}
	}
}

fn scanposts {
	posts=$1
	if(test -d $posts){
		for(name in `{ls -p $posts >[2]/dev/null | sort}){
			if(! ~ $name .* && test -f $posts^/^$name)
				indexpost $posts^/^$name
		}
	}
}

rm -rf $tmp
if(! mkdir -p $tmp/posts $tmp/targets)
	failstruct 'cannot create '^$tmp

scanposts $social^/self/posts

if(test -d $social^/feeds){
	for(feed in `{ls -p $social^/feeds >[2]/dev/null | sort}){
		if(test -d $social^/feeds/^$feed)
			scanposts $social^/feeds/^$feed^/posts
	}
}

if(test -d $index){
	if(! rm -rf $index)
		failstruct 'cannot remove old index'
}
if(! mv $tmp $index)
	failstruct 'cannot install index'

cleanup
exit ''
