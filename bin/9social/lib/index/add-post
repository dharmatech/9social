#!/bin/rc

fn usage {
	echo 'usage: 9social/lib/index/add-post <post-file>' >[1=2]
	exit usage
}

if(! ~ $#* 1)
	usage

if(~ $#indexroot 0)
	addpost_indexroot=$home^/lib/9social/index
if not
	addpost_indexroot=$indexroot
if(~ $#warn 0)
	addpost_warn=()
if not
	addpost_warn=$warn

post=$1
metadir=/tmp/9social
meta=$metadir^/index-add-post-meta.^$pid
metaerr=$metadir^/index-add-post-metaerr.^$pid
partial=0

fn cleanup {
	rm -f $meta $metaerr >[2]/dev/null
}

fn warnmsg {
	if(! ~ $#addpost_warn 0)
		echo $0^': '^$* >[1=2]
}

fn skip {
	warnmsg $*
	cleanup
	exit skipped
}

fn failstruct {
	echo $0^': '^$* >[1=2]
	cleanup
	exit failed
}

fn field {
	awk -F '	' -v 'k='$1 '$1==k && value=="" { value=$2 } END { if(value != "") print value }' $meta
}

if(! mkdir -p $metadir)
	failstruct 'cannot create '^$metadir
if(! mkdir -p $addpost_indexroot/posts $addpost_indexroot/targets)
	failstruct 'cannot create '^$addpost_indexroot

if(! 9social/lib/post/meta.awk $post >$meta >[2]$metaerr)
	skip 'skip post (bad format): '^$post

id=`{field id}
if(~ $#id 0)
	skip 'skip post (missing id): '^$post

encoded_id=`{9social/lib/id/encode.awk $id >[2]/dev/null}
if(! ~ $status '')
	skip 'skip post (malformed id): '^$post

post_index=$addpost_indexroot^/posts/^$encoded_id
if(test -f $post_index){
	old=`{cat $post_index >[2]/dev/null}
	warnmsg 'skip post (duplicate id): '^$post^' already indexed: '^$old
	cleanup
	exit skipped
}

if(! echo $post >$post_index)
	failstruct 'cannot write '^$post_index

type=`{field type}
if(! ~ $#type 0 && ~ $type reply like){
	target=`{field target}
	if(~ $#target 0){
		warnmsg 'skip relationship (missing target): '^$post
		partial=1
	}
	if not {
		encoded_target=`{9social/lib/id/encode.awk $target >[2]/dev/null}
		if(! ~ $status ''){
			warnmsg 'skip relationship (malformed target): '^$post
			partial=1
		}
		if not {
			if(~ $type reply)
				reldir=$addpost_indexroot^/targets/^$encoded_target^/replies
			if(~ $type like)
				reldir=$addpost_indexroot^/targets/^$encoded_target^/likes
			if(! mkdir -p $reldir)
				failstruct 'cannot create '^$reldir
			relfile=$reldir^/^$encoded_id
			if(! echo $post >$relfile)
				failstruct 'cannot write '^$relfile
		}
	}
}

cleanup
if(~ $partial 1)
	exit skipped
exit ''
