#!/bin/rc

fn fail {
	echo $0^': '^$* >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/lib/render-threads' >[1=2]
	exit usage
}

if(! ~ $#* 0)
	usage

social=$home^/lib/9social
index=$social^/index
records=/tmp/9social-render-threads.^$pid

fn cleanup {
	rm -f $records
}

if(! test -d $index/posts)
	fail 'index not found' 'no index'

>$records
for(entry in `{ls -p $index/posts >[2]/dev/null | sort}){
	post=`{cat $index/posts/$entry}
	if(test -f $post)
		9social/lib/post-thread-record.awk $post >>$records
}

9social/lib/render-thread-records.awk $records
st=$status
cleanup
exit $st
