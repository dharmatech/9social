#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/lib/check-self' >[1=2]
	exit usage
}

if(! ~ $#* 0) usage

self=$home/lib/9social/self
profile=$self/profile
posts=$self/posts

test -d $self         || fail $self^' does not exist'
test -e $self/.git    || fail $self^' is not a Git repository'
test -f $profile      || fail 'bad profile: '^$profile
9social/lib/valid-profile.awk $profile >/dev/null || fail 'bad profile: '^$profile

if(! test -d $posts){
	mkdir $posts >[2]/dev/null || fail 'cannot create posts'
}

exit ''
