#!/bin/rc

social=$home^/lib/9social
following=$social^/following

if(! ~ $#* 1){
	echo 'usage: 9social/follow <url>' >[1=2]
	exit usage
}

url=`{echo $1 | sed 's/^[ 	]*//; s/[ 	]*$//'}
if(~ $#url 0 || ~ $url ''){
	echo $0^': empty url' >[1=2]
	exit 'empty url'
}

if(! test -d $social){
	if(! mkdir -p $social >[2]/dev/null){
		echo $0^': cannot create '^$social >[1=2]
		exit 'cannot create local state path'
	}
}

if(! test -e $following){
	if(! echo -n >$following){
		echo $0^': cannot create '^$following >[1=2]
		exit 'cannot create following'
	}
}

for(line in `{cat $following}){
	if(~ $line $url)
		exit ''
}

if(test -s $following){
	last=`{tail -c 1 $following}
	if(! ~ $#last 0){
		if(! echo >>$following){
			echo $0^': cannot update '^$following >[1=2]
			exit 'cannot update following'
		}
	}
}

if(! echo $url >>$following){
	echo $0^': cannot update '^$following >[1=2]
	exit 'cannot update following'
}
