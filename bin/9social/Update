#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/Update' >[1=2]
	exit usage
}

fn relselfpost {
	awk -v 'self='^$self -v 'post='^$1 '
		BEGIN {
			prefix = self "/posts/"
			if(index(post, prefix) == 1 && length(post) > length(prefix)){
				print substr(post, length(self) + 2)
				exit 0
			}
			exit 1
		}
	'
}

fn validrelpath {
	awk -F/ '
		{
			for(i=1; i<=NF; i++)
				if($i == "" || $i == "..")
					exit 1
		}
	'
}

if(! ~ $#* 0)
	usage

if(~ $#% 0 || ~ $% '')
	fail 'no current Acme file'

post=$%
self=$home/lib/9social/self

check_self=9social/lib/check-self
check_post=9social/lib/check-post
post_id=9social/lib/post-id
if(~ $0 */Update){
	base=`{echo $0 | sed 's;/Update$;;'}
	check_self=$base/lib/check-self
	check_post=$base/lib/check-post
	post_id=$base/lib/post-id
}

$check_self
st=$status
if(! ~ $st '')
	fail 'self repository is not ready'

relpost=`{relselfpost $post}
st=$status
if(! ~ $st '' || ! ~ $#relpost 1)
	fail 'not a self post: '^$post

if(echo $relpost | validrelpath){}
if not
	fail 'bad post path: '^$relpost

if(! test -f $post)
	fail 'post file not found: '^$post

if(! ~ $#winid 0 && ! ~ $winid ''){
	ctl=/mnt/acme/$winid/ctl
	if(test -e $ctl){
		if(! echo put >$ctl)
			fail 'save failed'
	}
}

if(! $check_post $post)
	fail 'bad post: '^$post

postid=`{$post_id $post}
st=$status
if(! ~ $st '' || ! ~ $#postid 1)
	fail 'bad post id: '^$post

if(! cd $self)
	fail 'cannot enter self repository'

if(git/diff -s $relpost >/dev/null >[2]/dev/null){
	echo 'no changes: '^$relpost
	exit ''
}

if(! git/add $relpost)
	fail 'git add failed: '^$relpost
if(! git/commit -m 'update post: '^$postid $relpost)
	fail 'git commit failed: '^$relpost

echo 'updated: '^$relpost
exit ''
