#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/OpenPost' >[1=2]
	exit usage
}


if(! ~ $#* 0) usage

line=`{9social/lib/current-line} || fail 'cannot read current line'

ref=`{echo $line | 9social/lib/first-post-path.awk}
if(! ~ $status '' || ! ~ $#ref 1){
	ref=`{echo $line | 9social/lib/first-post-id.awk}
	if(! ~ $status '' || ! ~ $#ref 1)
		fail 'no post path on current line'
}

post=`{9social/lib/resolve-post $ref} || fail 'cannot resolve post: '^$ref
if(! ~ $#post 1)
	fail 'cannot resolve post: '^$ref

opened_id=`{9social/lib/post/id.awk $post} || fail 'bad post id: '^$post
if(! ~ $#opened_id 1)
	fail 'bad post id: '^$post
actions='9social/Reply 9social/Like'
if(~ $post $home/lib/9social/self/posts/^*)
	actions='9social/Reply 9social/Update 9social/Delete'
if not {
	if(9social/lib/liked-post $opened_id >/dev/null >[2]/dev/null)
		actions='9social/Reply'
}
target=`{9social/lib/post-target $post} || fail 'cannot read post target'
if(! ~ $#target 0){
	9social/lib/encode-id $target >/dev/null >[2]/dev/null
	if(~ $status '')
		actions='9social/OpenPost '^$actions
}
tag=' | '^$actions
9social/lib/open-file-window $post $tag || fail 'cannot open post'

exit ''
