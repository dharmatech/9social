#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/Publish' >[1=2]
	exit usage
}

if(! ~ $#* 0) usage

draft=$%
if(~ $#draft 0 || ~ $draft '')
	fail 'missing draft path'
if(! 9social/lib/valid-draft $draft)
	fail 'invalid draft path: '^$draft
if(! test -f $draft)
	fail 'draft file not found: '^$draft

if(! ~ $#winid 0 && ! ~ $winid ''){
	ctl=/mnt/acme/$winid/ctl
	if(test -e $ctl)
		echo put >$ctl || fail 'save failed'
}

9social/lib/publish-draft $draft || exit $status

echo 'draft removed; close the Acme window with Del'
exit ''
