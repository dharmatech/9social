#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/Publish' >[1=2]
	exit usage
}

fn validdraft {
	awk -v 'home='$home '
		BEGIN {
			homepat = home "/tmp/9social-new-post\\.[0-9]+(\\.[0-9]+)?$"
			tmppat = "^/tmp/9social-new-post\\.[0-9]+(\\.[0-9]+)?$"
		}
		$0 ~ "^" homepat { ok=1 }
		$0 ~ tmppat { ok=1 }
		END { if(!ok) exit 1 }
	'
}

if(! ~ $#* 0)
	usage

publish=9social/lib/publish-draft
if(~ $0 */Publish)
	publish=`{echo $0 | sed 's;/Publish$;/lib/publish-draft;'}

draft=$%
if(~ $#draft 0 || ~ $draft '')
	fail 'missing draft path'
if(! echo $draft | validdraft)
	fail 'invalid draft path: '^$draft
if(! test -f $draft)
	fail 'draft file not found: '^$draft

if(! ~ $#winid 0 && ! ~ $winid ''){
	ctl=/mnt/acme/$winid/ctl
	if(test -e $ctl){
		if(! echo put >$ctl)
			fail 'save failed'
	}
}

$publish $draft
st=$status
if(! ~ $st '')
	exit $st

echo 'draft removed; close the Acme window with Del'
exit ''
