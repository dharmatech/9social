#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ‾ $#draft 0)
		echo 'draft: '^$draft >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/NewPost' >[1=2]
	exit usage
}

if(! ‾ $#* 0) usage

draft=()
if(! test -f /mnt/wsys/index){
	echo 'NewPost: acme window system not available' >[1=2]
	echo 'NewPost: run from acme, or use 9social/new-post' >[1=2]
	exit 'no acme'
}

9social/lib/check-self || exit $status

draft=`{9social/lib/new-post-draft} ||
	fail 'cannot create draft'

9social/lib/open-draft-window $draft || exit $status

exit ''
