#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ‾ $#threadfile 0)
		echo 'threads: '^$threadfile >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/ShowThreads' >[1=2]
	exit usage
}

if(! ‾ $#* 0) usage

threadfile=()
threadfile=`{9social/lib/mk-temp-file threads} ||
	fail 'cannot create threads temp file'

9social/show-threads >$threadfile ||
	fail 'cannot create threads view'
if(! test -f $threadfile) fail 'cannot create threads view'

if(! 9social/lib/open-file-window $threadfile ' | 9social/OpenPost')
	exit $status

exit ''
