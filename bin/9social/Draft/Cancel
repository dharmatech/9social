#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/Draft/Cancel' >[1=2]
	exit usage
}

if(! ~ $#* 0)
	usage

draft=$%
if(~ $#draft 0 || ~ $draft '')
	fail 'missing draft path'
if(! 9social/lib/draft/valid.awk $draft)
	fail 'invalid draft path: '^$draft
if(! test -f $draft)
	fail 'draft file not found: '^$draft
if(! rm -f $draft $draft^.meta)
	fail 'cannot remove draft: '^$draft

echo 'cancelled: '^$draft
exit ''
