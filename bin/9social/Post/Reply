#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ‾ $#draft 0)
		echo 'draft: '^$draft >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/Post/Reply' >[1=2]
	exit usage
}

if(! ‾ $#* 0)
	usage

draft=()
if(! test -f /mnt/wsys/index){
	echo 'Reply: acme window system not available' >[1=2]
	echo 'Reply: run from an acme post window' >[1=2]
	exit 'no acme'
}

source=$%
if(‾ $#source 0 || ‾ $source '')
	fail 'missing post path'

if(! 9social/lib/check-self)
	exit $status

draft=`{9social/lib/reply-draft $source}
st=$status
if(! ‾ $st '')
	exit $st

9social/lib/open-draft-window $draft || exit $status

exit ''
