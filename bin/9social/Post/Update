#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/Post/Update' >[1=2]
	exit usage
}

if(! ~ $#* 0)
	usage

if(~ $#% 0 || ~ $% '')
	fail 'no current Acme file'

post=$%
self=$home/lib/9social/self

if(! 9social/lib/check-self)
	fail 'self repository is not ready'

relpost=`{9social/lib/post/self-path $post}
if(! ~ $status '' || ! ~ $#relpost 1)
	fail 'not a self post: '^$post

if(! test -f $post)
	fail 'post file not found: '^$post

if(! ~ $#winid 0 && ! ~ $winid ''){
	ctl=/mnt/acme/$winid/ctl
	if(test -e $ctl){
		if(! echo put >$ctl)
			fail 'save failed'
	}
}

if(! 9social/lib/post/check.awk $post)
	fail 'bad post: '^$post

postid=`{9social/lib/post/id.awk $post}
st=$status
if(! ~ $st '' || ! ~ $#postid 1)
	fail 'bad post id: '^$post

if(! cd $self)
	fail 'cannot enter self repository'

if(git/diff -s $relpost >/dev/null >[2]/dev/null){
	echo 'no changes: '^$relpost
	exit ''
}

if(! git/add $relpost)
	fail 'git add failed: '^$relpost
if(! git/commit -m 'update post: '^$postid $relpost)
	fail 'git commit failed: '^$relpost

echo 'updated: '^$relpost
exit ''
