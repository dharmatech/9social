#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/cmd/push' >[1=2]
	exit usage
}

if(! ~ $#* 0)
	usage

9social/lib/check-self
st=$status
if(! ~ $st '')
	exit $st

self=$home/lib/9social/self
if(~ $#gitcmd 0)
	gitcmd=git/push

@{cd $self && $gitcmd}
st=$status
if(! ~ $st '')
	fail 'git push failed'

exit ''
