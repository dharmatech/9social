#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ‾ $#draft 0)
		echo 'draft: '^$draft >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/cmd/new-post [-]' >[1=2]
	exit usage
}

draft=()
mode=editor

if(‾ $#* 0)
	mode=editor
if not if(‾ $#* 1 && ‾ $1 -)
	mode=stdin
if not
	usage

if(‾ $mode stdin){
	draft=`{9social/lib/mk-temp-file 9social-new-post} ||
		fail 'cannot create draft temp file'
	cat >$draft || fail 'cannot read stdin'
}
if not {
	draft=`{9social/lib/new-post-draft} ||
		fail 'cannot create draft'
	if(‾ $#editor 0)
		editor=sam
	$editor $draft || fail 'editor failed'
}

9social/lib/draft/publish $draft
st=$status
if(! ‾ $st ''){
	if(echo $st | grep 'empty$' >/dev/null){
		rm -f $draft >[2]/dev/null
		echo 'new-post: cancelled'
		exit ''
	}
}
exit $st
