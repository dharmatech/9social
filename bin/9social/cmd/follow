#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

social=$home^/lib/9social
self=$social^/self
following=$self^/following

if(! ~ $#* 1){
	echo 'usage: 9social/cmd/follow <url>' >[1=2]
	exit usage
}

url=`{echo $1 | sed 's/^[ 	]*//; s/[ 	]*$//'}
if(~ $#url 0 || ~ $url '')
	fail 'empty url'

if(! test -d $social){
	if(! mkdir -p $social >[2]/dev/null)
		fail 'cannot create '^$social
}
if(! test -d $self){
	if(! mkdir -p $self >[2]/dev/null)
		fail 'cannot create '^$self
}
if(test -e $following >[2]/dev/null){
	if(! test -f $following)
		fail 'cannot update '^$following
}
if not {
	if(! echo -n >$following)
		fail 'cannot create '^$following
}

tmp=$social^/following.^$pid^.tmp
{
	cat $following
	echo $url
} | awk '{
	gsub(/^[ \t]+/, "")
	gsub(/[ \t]+$/, "")
	if($0 != "") print
}' | sort | uniq >$tmp
if(! ~ $status ''){
	rm -f $tmp >[2]/dev/null
	fail 'cannot update '^$following
}

if(cmp $following $tmp >/dev/null >[2]/dev/null){
	rm -f $tmp >[2]/dev/null
	exit ''
}

if(! cp $tmp $following){
	rm -f $tmp >[2]/dev/null
	fail 'cannot update '^$following
}
rm -f $tmp >[2]/dev/null

if(test -d $self/.git){
	if(! @{cd $self && git/add following})
		fail 'git add failed: following'
	if(! @{cd $self && git/commit -m 'follow: '^$url following})
		fail 'git commit failed: following'
}

exit ''
