#!/bin/rc

social=$home^/lib/9social
self=$social^/self
feeds=$social^/feeds
tmp=/tmp/9social.timeline.$pid
sorted=$tmp^.sorted

if(! ~ $#* 0){
	echo 'usage: 9social/cmd/timeline' >[1=2]
	exit usage
}

if(! test -d $self && ! test -d $feeds)
	exit ''

if(! echo -n >$tmp){
	echo $0^': cannot create '^$tmp >[1=2]
	exit 'cannot create temp file'
}

feedlist=()
if(test -d $self)
	feedlist=($feedlist $self)
if(test -d $feeds)
	feedlist=($feedlist $feeds/*)

for(feed in $feedlist){
	if(test -d $feed){
		if(! test -f $feed/profile){
			echo $0^': skip feed (missing profile): '^$feed >[1=2]
		}
		if(test -f $feed/profile){
			if(! test -d $feed/posts){
				echo $0^': skip feed (missing posts): '^$feed >[1=2]
			}
			if(test -d $feed/posts){
				if(! 9social/lib/valid-profile.awk $feed/profile >/dev/null >[2]/dev/null){
					echo $0^': skip feed (bad profile): '^$feed >[1=2]
				}
				if not {
					for(post in $feed/posts/*){
						postbase=`{basename $post}
						if(! ~ $postbase .*){
							if(test -f $post){
								if(! 9social/lib/post/timeline-record.awk $feed/profile $post >>$tmp){
									echo $0^': skip post (bad format): '^$post >[1=2]
								}
							}
						}
					}
				}
			}
		}
	}
}

if(! test -s $tmp){
	rm -f $tmp $sorted
	exit ''
}

sort -t '	' -k 1,1r -k 2,2 -k 3,3 $tmp >$sorted
if(! ~ $status ''){
	rm -f $tmp $sorted
	echo $0^': cannot sort timeline' >[1=2]
	exit 'cannot sort timeline'
}

9social/lib/render-timeline-records.awk $sorted

rm -f $tmp $sorted
