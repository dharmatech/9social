#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ‾ $#menufile 0)
		echo 'menu: '^$menufile >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/Menu' >[1=2]
	exit usage
}

if(! ‾ $#* 0)
	usage

if(! test -f /mnt/wsys/index){
	echo 'Menu: acme window system not available' >[1=2]
	echo 'Menu: run from acme' >[1=2]
	exit 'no acme'
}

menufile=`{9social/lib/mk-temp-file menu} ||
	fail 'cannot create menu temp file'

>$menufile {
	echo '9social/Timeline'
	echo '9social/ShowThreads'
	echo '9social/NewPost'
	echo '9social/cmd/follow'
	echo '9social/cmd/refresh'
	echo '9social/cmd/push'
}

if(! 9social/lib/open-file-window $menufile '')
	exit $status

exit ''
