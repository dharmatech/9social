#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	if(! ‾ $#draft 0)
		echo 'draft: '^$draft >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/new-post [-]' >[1=2]
	exit usage
}

draft=()
mode=editor
publish=9social/lib/publish-draft
if(‾ $0 */new-post)
	publish=`{echo $0 | sed 's;/new-post$;/lib/publish-draft;'}

if(‾ $#* 0)
	mode=editor
if not if(‾ $#* 1 && ‾ $1 -)
	mode=stdin
if not
	usage

if(test -d $home^/tmp)
	tmpdir=$home^/tmp
if not
	tmpdir=/tmp

draft=$tmpdir^/9social-new-post.^$pid
if(test -e $draft)
	draft=$tmpdir^/9social-new-post.^$pid^.^`{date -n}

if(‾ $mode stdin){
	if(! cat >$draft)
		fail 'cannot read stdin'
}
if not {
	if(! echo 'Title: ' >$draft)
		fail 'cannot create draft'
	if(‾ $#editor 0)
		editor=sam
	if(! $editor $draft)
		fail 'editor failed'
}

$publish $draft
st=$status
if(! ‾ $st ''){
	if(echo $st | grep 'empty$' >/dev/null){
		rm -f $draft >[2]/dev/null
		echo 'new-post: cancelled'
		exit ''
	}
}
exit $st
