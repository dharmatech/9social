#!/bin/rc

fn fail {
	echo $0^': '^$1 >[1=2]
	exit $1
}

fn usage {
	echo 'usage: 9social/Like' >[1=2]
	exit usage
}

if(! ~ $#* 0)
	usage

if(! test -f /mnt/wsys/index){
	echo 'Like: acme window system not available' >[1=2]
	echo 'Like: run from an acme post window' >[1=2]
	exit 'no acme'
}

source=$%
if(~ $#source 0 || ~ $source '')
	fail 'missing post path'

9social/like $source
exit $status
